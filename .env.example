# Thirdweb client ID for wallet connect and Insight API
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here

# Active attestation chain: omachain-testnet or omachain-mainnet
NEXT_PUBLIC_ACTIVE_CHAIN=omachain-testnet

# Asset prefix for serving CSS/JS when proxied through another domain (set in Vercel)
# NEXT_PUBLIC_ASSET_PREFIX=https://omatrust-widgets.vercel.app

# Relay base URL for delegated attestation API
# For local dev, point to the rep-attestation-frontend (e.g., http://localhost:3001)
# In production, leave unset to use https://reputation.omatrust.org
# NEXT_PUBLIC_RELAY_BASE_URL=http://localhost:3001
